# ────────────────────────────────────────────────────────────────────────────
# Application
# ────────────────────────────────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8080
# APP_BASE_URL=http://localhost:8080
# Required when auth is enabled. Make sure to generate a secure random secret key (e.g. using `openssl rand -hex 32` or python `import secrets; print(secrets.token_hex(32))`).
# CRITICAL: DO NOT leave this as default if the application is accessible on non-local networks.
APP_SECRET_KEY=change-me-to-a-random-secret-key-do-not-use-in-production

# ────────────────────────────────────────────────────────────────────────────
# Auth (highly recommended for non-local access)
# ────────────────────────────────────────────────────────────────────────────
# Enable HTTP Basic Authentication. Set to true if exposing the web interface beyond localhost.
# WARNING: Do not expose the app directly to the public internet without enabling auth.
AUTH_ENABLED=false
# If auth is enabled, set a strong username and password below:
# AUTH_USERNAME=admin
# AUTH_PASSWORD=make-sure-to-use-a-strong-password-here

# ────────────────────────────────────────────────────────────────────────────
# Infrastructure
# ────────────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
DATABASE_URL=sqlite+aiosqlite:////data/app.db

# ────────────────────────────────────────────────────────────────────────────
# Paths & Placeholders Mapping
# ────────────────────────────────────────────────────────────────────────────
# Note: For Proxmox/Native VM installs, the following user placeholders map to these variables:
#   - AUDIOBOOKSHELF_IMPORT_DIR  => OUTPUT_ROOT (Destination directory ABS scans)
#   - DOWNLOAD_DIR               => WORK_DIR (Where videos are downloaded/converted)
#   - TEMP_DIR                   => WORK_DIR (Temporary workspace)
#   - METADATA_DIR               => ARCHIVE_FILE directory or SQLite database directory
#   - COOKIES_FILE               => Map using YTDLP_EXTRA_ARGS=--cookies /path/to/cookies.txt
#   - UID/GID                    => Configure PUID/PGID to match NFS/local owner permissions (Docker mode)

WORK_DIR=/data/work
ARCHIVE_FILE=/data/config/youtube-archive.txt

# Audiobookshelf Output Directory Configuration (Docker compose binds)
# HOST_PODCASTS_DIR: The directory on your Docker host machine where podcasts are stored.
#   - Mac example: /Volumes/Synology/Media/Podcasts
#   - Linux/Proxmox example: /mnt/podcasts
HOST_PODCASTS_DIR=/mnt/podcasts

# CONTAINER_PODCASTS_DIR: The mount path inside the Docker containers.
#   - Normally: /media/podcasts
CONTAINER_PODCASTS_DIR=/media/podcasts

# OUTPUT_ROOT: The path the application writes to. When running under Docker,
# this MUST match CONTAINER_PODCASTS_DIR.
OUTPUT_ROOT=/media/podcasts

# ────────────────────────────────────────────────────────────────────────────
# Download behaviour
# ────────────────────────────────────────────────────────────────────────────
ALLOW_PLAYLISTS=false
ALLOW_CHANNELS=false
# DEFAULT_DESTINATION_FOLDER=

YTDLP_BIN=yt-dlp
FFMPEG_BIN=ffmpeg
FFPROBE_BIN=ffprobe
YTDLP_AUDIO_FORMAT=m4a
YTDLP_AUDIO_QUALITY=
# YTDLP_EXTRA_ARGS=
# FFMPEG_EXTRA_ARGS=

OUTPUT_EXTENSION=m4b
FILENAME_TEMPLATE={title}.m4b
FOLDER_NAME_FIELD=uploader_id
FOLDER_NAME_FALLBACKS=uploader_id,channel_id,channel,uploader

# ────────────────────────────────────────────────────────────────────────────
# Job management
# ────────────────────────────────────────────────────────────────────────────
MAX_CONCURRENT_JOBS=1
JOB_TIMEOUT_SECONDS=10800
RETRY_MAX=3
RETRY_INTERVAL_SECONDS=60,300,900
CLEANUP_TEMP_ON_SUCCESS=true
CLEANUP_TEMP_ON_FAILURE=false
COLLISION_MODE=append_id   # skip | overwrite | append_id | append_counter

# ────────────────────────────────────────────────────────────────────────────
# Audiobookshelf (optional)
# ────────────────────────────────────────────────────────────────────────────
# ABS_BASE_URL=http://audiobookshelf:13378
# ABS_API_TOKEN=your-abs-api-token
# ABS_LIBRARY_ID=your-library-id
ABS_SCAN_AFTER_SUCCESS=false

# ────────────────────────────────────────────────────────────────────────────
# Development
# ────────────────────────────────────────────────────────────────────────────
DRY_RUN=false
