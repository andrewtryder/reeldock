{
  "manifest_version": 3,
  "name": "ABS Media Importer",
  "description": "Queue YouTube videos into a local ABS Media Importer instance.",
  "version": "1.7.0",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Queue video with ABS Media Importer",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": { "page": "options.html", "open_in_tab": false },
  "permissions": ["activeTab", "storage", "contextMenus", "tabs", "notifications"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://m.youtube.com/*",
    "https://youtu.be/*",
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://*/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}
