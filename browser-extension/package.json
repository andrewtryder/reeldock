{
  "name": "abs-media-importer-extension",
  "version": "1.7.0",
  "description": "Browser extension for queuing YouTube videos into a local abs-media-importer instance.",
  "private": true,
  "type": "module",
  "scripts": {
    "lint": "node scripts/lint.mjs",
    "build:chrome": "node scripts/build.mjs chrome",
    "build:firefox": "node scripts/build.mjs firefox",
    "build": "node scripts/build.mjs",
    "package:chrome": "npm run build:chrome && node scripts/package-chrome.mjs",
    "package:firefox": "npm run build:firefox && node scripts/package-firefox.mjs",
    "package": "npm run package:chrome && npm run package:firefox",
    "check:version": "node scripts/check-version.mjs"
  },
  "license": "MIT"
}
