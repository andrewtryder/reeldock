{
  "packages": {
    ".": {
      "release-type": "simple",
      "exclude-paths": [
        "browser-extension/**"
      ],
      "extra-files": [
        {
          "type": "toml",
          "path": "pyproject.toml",
          "jsonpath": "$.project.version"
        }
      ]
    },
    "browser-extension": {
      "component": "browser-extension",
      "release-type": "node",
      "include-component-in-tag": true,
      "extra-files": [
        {
          "type": "json",
          "path": "manifests/base.json",
          "jsonpath": "$.version"
        }
      ]
    }
  }
}
